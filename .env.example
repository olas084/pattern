GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ENABLED=true
GROQ_TIMEOUT_MS=120000
GROQ_MAX_RETRY=4

MONGO_URI=mongodb://localhost:27017/trading-app

# Optional: if no local data/backtesting.duckdb exists, the start script downloads from this URL
DUCKDB_URL=

# Optional tuning
GROQ_UNIVERSAL_MAX_ROUNDS=30
GROQ_UNIVERSAL_TARGET_SUCCESS=3
GROQ_UNIVERSAL_MIN_ACTIVE_PER_SIDE=1

# Symbols override (comma-separated). Leave empty to use default 13 symbols.
BACKTEST_SYMBOLS=

